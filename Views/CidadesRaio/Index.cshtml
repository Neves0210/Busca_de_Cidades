@model SistemaCidadesRaio.Models.BuscaCidadesRaioViewModel

@{
    ViewData["Title"] = "Busca de cidades por raio";
}

<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header">
            <h4 class="mb-0">Buscar cidades por raio</h4>
        </div>
        <div class="card-body">
            <form asp-action="Index" method="post">
                <div class="row g-3">
                    <div class="col-md-2">
                        <label asp-for="DddSelecionado" class="form-label">DDD</label>
                        <select asp-for="DddSelecionado" asp-items="Model.Ddds" class="form-select" onchange="this.form.submit()">
                            <option value="">Selecione</option>
                        </select>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="CidadeOrigemId" class="form-label">Cidade de origem</label>
                        <select asp-for="CidadeOrigemId" asp-items="Model.Cidades" class="form-select">
                            <option value="">Selecione</option>
                        </select>
                    </div>

                    <div class="col-md-3">
                        <label asp-for="RaioKm" class="form-label">Raio (km)</label>
                        <input asp-for="RaioKm" class="form-control" type="number" step="0.1" min="1" />
                    </div>

                    <div class="col-md-2">
                        <label asp-for="QuantidadeMaxima" class="form-label">Quantidade máxima</label>
                        <input asp-for="QuantidadeMaxima" class="form-control" type="number" min="1" />
                    </div>

                    <div class="col-md-1 d-flex align-items-end">
                        <button type="submit" class="btn btn-primary w-100">Buscar</button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    @if (Model.Resultados.Any())
    {
        <div class="card shadow-sm mt-4">
            <div class="card-header">
                <h5 class="mb-0">Resultados</h5>
            </div>
            <div class="card-body">
                <table class="table table-striped table-bordered">
                    <thead>
                        <tr>
                            <th>Cidade</th>
                            <th>UF</th>
                            <th>Latitude</th>
                            <th>Longitude</th>
                            <th>Distância (km)</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Resultados)
                        {
                            <tr>
                                <td>@item.Nome</td>
                                <td>@item.UF</td>
                                <td>@item.Latitude</td>
                                <td>@item.Longitude</td>
                                <td>@item.DistanciaKm</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

    <script>
        $(document).ready(function () {
            $('#DddSelecionado').select2({
                placeholder: 'Selecione um DDD',
                allowClear: true,
                width: '100%'
            });

            $('#CidadeOrigemId').select2({
                placeholder: 'Selecione uma cidade',
                allowClear: true,
                width: '100%'
            });
        });
    </script>
}