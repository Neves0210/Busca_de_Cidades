@model SistemaCidadesRaio.Models.BuscaCidadesRaioViewModel

@{
    ViewData["Title"] = "Busca de cidades por raio";
}

<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
<link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css" />

<style>
    #map {
        min-height: 550px;
        width: 100%;
    }
</style>

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header">
            <h4 class="mb-0">Buscar cidades por raio</h4>
        </div>
        <div class="card-body">
            <form asp-action="Index" method="post">
                <div class="row g-3">
                    <div class="col-md-2">
                        <label asp-for="DddSelecionado" class="form-label">DDD</label>
                        <select asp-for="DddSelecionado" asp-items="Model.Ddds" class="form-select" onchange="this.form.submit()">
                            <option value="">Selecione</option>
                        </select>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="CidadeOrigemId" class="form-label">Cidade de origem</label>
                        <select asp-for="CidadeOrigemId" asp-items="Model.Cidades" class="form-select">
                            <option value="">Selecione</option>
                        </select>
                    </div>

                    <div class="col-md-3">
                        <label asp-for="RaioKm" class="form-label">Raio (km)</label>
                        <input asp-for="RaioKm" class="form-control" type="number" step="0.1" min="1" />
                    </div>

                    <div class="col-md-2">
                        <label asp-for="QuantidadeMaxima" class="form-label">Quantidade máxima</label>
                        <input asp-for="QuantidadeMaxima" class="form-control" type="number" min="1" />
                    </div>

                    <div class="col-md-1 d-flex align-items-end">
                        <button type="submit" class="btn btn-primary w-100">Buscar</button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    @if (Model.Resultados.Any() && Model.CidadeOrigem != null)
    {
        <div class="row mt-4">
            <div class="col-md-5">
                <div class="card shadow-sm h-100">
                    <div class="card-header">
                        <h5 class="mb-0">Resultados</h5>
                    </div>
                    <div class="card-body">
                        <table class="table table-striped table-bordered">
                            <thead>
                                <tr>
                                    <th>Cidade</th>
                                    <th>UF</th>
                                    <th>Distância (km)</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.Resultados)
                                {
                                    <tr>
                                        <td>@item.Nome</td>
                                        <td>@item.UF</td>
                                        <td>@item.DistanciaKm</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="col-md-7">
                <div class="card shadow-sm">
                    <div class="card-header">
                        <h5 class="mb-0">Mapa</h5>
                    </div>
                    <div class="card-body">
                        <div id="map" style="height: 550px; width: 100%; border-radius: 8px; background: #f3f4f6;"></div>
                    </div>
                </div>
            </div>
        </div>

        <script id="cidadeOrigemJson" type="application/json">
            @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.CidadeOrigem))
        </script>

        <script id="resultadosJson" type="application/json">
            @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Resultados))
        </script>
    }
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>

    <script>
        $(document).ready(function () {
            $('#DddSelecionado').select2({
                placeholder: 'Selecione um DDD',
                allowClear: true,
                width: '100%'
            });

            $('#CidadeOrigemId').select2({
                placeholder: 'Selecione uma cidade',
                allowClear: true,
                width: '100%'
            });

            const origemEl = document.getElementById('cidadeOrigemJson');
            const resultadosEl = document.getElementById('resultadosJson');
            const mapEl = document.getElementById('map');

            if (!origemEl || !resultadosEl || !mapEl) return;

            const origem = JSON.parse(origemEl.textContent);
            const resultados = JSON.parse(resultadosEl.textContent);
            const raioKm = parseFloat(document.getElementById('RaioKm')?.value || '0');

            console.log('Origem:', origem);
            console.log('Resultados:', resultados);
            console.log('Leaflet:', typeof L);

            if (!origem || origem.Latitude == null || origem.Longitude == null) return;

            const origemLat = Number(origem.Latitude);
            const origemLng = Number(origem.Longitude);

            if (isNaN(origemLat) || isNaN(origemLng)) return;

            const origemLatLng = [origemLat, origemLng];

            const map = L.map('map', {
                preferCanvas: true
            });

            map.setView(origemLatLng, 9);

            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                attribution: '&copy; OpenStreetMap',
                maxZoom: 19
            }).addTo(map);

            const markerOrigem = L.marker(origemLatLng)
                .addTo(map)
                .bindPopup(`<b>${origem.Nome}/${origem.UF}</b><br>Cidade de origem`);

            const circle = L.circle(origemLatLng, {
                radius: raioKm * 1000,
                color: '#2563eb',
                fillColor: '#60a5fa',
                fillOpacity: 0.15,
                weight: 2
            }).addTo(map);

            const bounds = L.latLngBounds([origemLatLng]);

            resultados.forEach(cidade => {
                const lat = Number(cidade.Latitude);
                const lng = Number(cidade.Longitude);

                if (isNaN(lat) || isNaN(lng)) return;

                const latLng = [lat, lng];

                L.marker(latLng)
                    .addTo(map)
                    .bindPopup(`<b>${cidade.Nome}/${cidade.UF}</b><br>${cidade.DistanciaKm} km`);

                bounds.extend(latLng);
            });

            bounds.extend(circle.getBounds().getNorthEast());
            bounds.extend(circle.getBounds().getSouthWest());

            setTimeout(function () {
                map.invalidateSize();
                map.fitBounds(bounds, { padding: [30, 30] });
                markerOrigem.openPopup();
            }, 400);
        });
    </script>
}